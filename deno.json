{
  "tasks": {
    "check": "deno check s3si.ts",
    "fmt": "deno fmt",
    "fmt:check": "deno fmt --check",
    "lint": "deno lint",
    "run": "deno run -A",
    "gui": "deno run -A --unstable ./gui/main.ts"
  },
  "fmt": {
    "files": {
      "exclude": [
        "export/",
        "cache/",
        ".vscode/",
        ".github/",
        "profile.json"
      ]
    }
  },
  "importMap": "./import_map.json",
  "compilerOptions": {
    "jsx": "react-jsx",
    "jsxImportSource": "preact"
  }
}